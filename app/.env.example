# Copy to .env.local and fill in. Never commit real secrets.
# https://supabase.com/dashboard — Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Canonical public URL (no trailing slash). Used for auth email redirects (reset, confirm).
# Must match Supabase Dashboard → Authentication → URL Configuration (Site URL / redirect allowlist).
# Local: http://localhost:3000  Production: https://your-domain.com
NEXT_PUBLIC_SITE_URL=

# Optional: unset or "default" = free-tier routing in dev (matches typical production).
# "premium" = treat app as fully unlocked for local testing (still needs Supabase for login).
# See src/lib/config/access-mode.ts
# NEXT_PUBLIC_ACCESS_MODE=premium
