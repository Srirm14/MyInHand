# Access tier for The Fluid Ledger (Next.js reads this at build time for NEXT_PUBLIC_*).
# Copy to .env.local and adjust.
#
# default — Free tier: Salary + Lifestyle only; Offers / Forecast / EMI / Premium hub → paywall.
# premium — Full tools: /premium/* routes work; paywall shows an “already unlocked” notice.
#
NEXT_PUBLIC_ACCESS_MODE=default
