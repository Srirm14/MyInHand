# Copy to .env.local and fill in. Never commit real secrets.
# https://supabase.com/dashboard — Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Canonical public URL (no trailing slash). Used for auth email redirects (reset, confirm).
# Must match Supabase Dashboard → Authentication → URL Configuration (Site URL / redirect allowlist).
# Local: http://localhost:3000  Production: https://your-domain.com
NEXT_PUBLIC_SITE_URL=

# Optional: unset or "default" = free-tier routing in dev (matches typical production).
# "premium" = treat app as fully unlocked for local testing (still needs Supabase for login).
# See src/lib/config/access-mode.ts
# NEXT_PUBLIC_ACCESS_MODE=premium

## ─────────────────────────────────────────────────────────────────────────────
## Razorpay (Test mode for now; production-ready structure)
## ─────────────────────────────────────────────────────────────────────────────
#
# Public key (safe in browser). Use Test Key ID now; swap to Live Key ID later.
NEXT_PUBLIC_RAZORPAY_KEY_ID=
#
# Secret key (SERVER ONLY). Use Test Key Secret now; swap to Live Key Secret later.
RAZORPAY_KEY_SECRET=
#
# Plan IDs (create in Razorpay Dashboard → Subscriptions → Plans)
# Keep monthly and yearly as separate plans.
RAZORPAY_PLAN_ID_MONTHLY=
RAZORPAY_PLAN_ID_YEARLY=
#
# Optional but recommended for webhooks (Razorpay Dashboard → Webhooks)
RAZORPAY_WEBHOOK_SECRET=
#
# Server-only Supabase key used to update billing entitlements securely.
# Supabase Dashboard → Project Settings → API → service_role key.
SUPABASE_SERVICE_ROLE_KEY=
