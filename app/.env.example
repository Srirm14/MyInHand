# Access tier (optional). Copy to .env.local only when you need to override dev defaults.
#
# Unset in `npm run dev` → premium (full tools) for easy testing.
# Unset in production build → default (paywall) unless you set premium below.
#
# NEXT_PUBLIC_ACCESS_MODE=default   # force paywall even in dev
# NEXT_PUBLIC_ACCESS_MODE=premium   # force full tools in production builds too
#
# NEXT_PUBLIC_ACCESS_MODE=default
